{
	"name": "cross-seed-workspace",
	"version": "0.0.0",
	"description": "Cross-seed monorepo workspace",
	"private": true,
	"type": "module",
	"workspaces": [
		"cross-seed",
		"shared",
		"webui",
		"api-types",
		"cross-seed.org"
	],
	"scripts": {
		"test": "npm --workspaces run test --if-present",
		"coverage": "npm --workspaces run coverage --if-present",
		"build": "npm -w cross-seed run build:all",
		"build:docs": "npm -w cross-seed.org run build",
		"build:sea": "npm run build && node scripts/build-sea.js",
		"build:api-types": "npm -w api-types run build",
		"build:types": "tsc -b cross-seed/tsconfig.build.json api-types/tsconfig.build.json --force",
		"build:webui": "npm -w webui run build",
		"build:all": "npm run build",
		"watch": "npm -w cross-seed run watch",
		"dev": "npm -w cross-seed run build && concurrently --names \"TS,BE,FE\" --prefix-colors \"blue,green,magenta\" \"npm -w cross-seed run watch\" \"CROSS_SEED_DEV_LOGIN=true node --watch cross-seed/dist/cmd.js daemon\" \"npm -w webui run dev\"",
		"dev:backend": "npm -w cross-seed run build && node --watch cross-seed/dist/cmd.js daemon",
		"dev:frontend": "npm -w webui run dev",
		"dev-login": "node cross-seed/dist/cmd.js dev-login",
		"seed-test-data": "node scripts/seed-test-data.js",
		"prepare": "node -e \"const fs=require('fs'); if(!fs.existsSync('.git')) process.exit(0); require('child_process').execSync('husky',{stdio:'inherit'})\"",
		"lint": "npm --workspaces run lint --if-present",
		"typecheck": "npm --workspaces run typecheck --if-present",
		"format": "prettier --write . --ignore-path .gitignore",
		"format:check": "prettier --check . --ignore-path .gitignore",
		"release": "node scripts/release.js --"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@types/bcryptjs": "^2.4.6",
		"@types/bencode": "^2.0.1",
		"@types/ms": "^2.1.0",
		"@types/node": "^25.9.1",
		"@types/xml2js": "^0.4.9",
		"@types/xmlrpc": "^1.3.6",
		"@vitest/coverage-v8": "^4.1.0",
		"bencode": "^4.0.0",
		"concurrently": "^9.1.2",
		"eslint": "^9.39.4",
		"eslint-plugin-import-x": "^4.16.2",
		"globals": "^17.4.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"prettier": "^3.8.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"rimraf": "^6.1.3",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.60.0",
		"vite": "^8.0.14",
		"vitest": "^4.1.0"
	},
	"prettier": {
		"tabWidth": 4,
		"useTabs": true,
		"proseWrap": "always"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx}": "eslint --cache",
		"*.{js,jsx,json,ts,tsx,css,md}": "prettier --write"
	}
}
