{
	"compilerOptions": {
		"outDir": "./dist",
		"allowJs": true,
		"target": "es2022",
		"lib": ["es2023"],
		"module": "nodenext",
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"sourceMap": true,
		"strictNullChecks": true,
		"paths": {
			"@cross-seed/shared/constants": ["../shared/constants.ts"],
			"@cross-seed/shared/configSchema": ["../shared/configSchema.ts"],
			"@cross-seed/shared/utils": ["../shared/utils.ts"]
		}
	},
	"include": ["./src/**/*", "./tests/**/*"]
}
